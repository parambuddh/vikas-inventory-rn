generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SALESMAN
}

model User {
  id            Int      @id @default(autoincrement())
  first_name    String
  last_name     String
  phone         String   @unique
  email         String?  @unique
  password_hash String
  address       String?
  photo_url     String?
  role          Role     @default(SALESMAN)
  is_active     Boolean  @default(true)
  created_by    Int?     // ID of the admin who created this user
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  creator       User?    @relation("UserCreator", fields: [created_by], references: [id])
  created_users User[]   @relation("UserCreator")
  created_customers Customer[] @relation("CustomerCreator")
  created_products  Product[]  @relation("ProductCreator")
  created_inventory_logs InventoryLog[] @relation("InventoryLogCreator")
  created_orders    Order[]    @relation("OrderCreator")
  created_payments  Payment[]  @relation("PaymentCreator")
  visits            Visit[]    @relation("SalesmanVisits")

  @@map("users")
}

model Customer {
  id                    Int      @id @default(autoincrement())
  shop_name             String
  owner_name            String
  phone                 String   @unique
  alternate_phone       String?
  email                 String?
  address               String
  gst_number            String?
  area                  String?
  notes                 String?
  latitude              Float?
  longitude             Float?
  total_orders_amount   Decimal  @default(0) @db.Decimal(10, 2)
  total_received_amount Decimal  @default(0) @db.Decimal(10, 2)
  pending_amount        Decimal  @default(0) @db.Decimal(10, 2)
  is_active             Boolean  @default(true)
  created_by            Int
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  creator               User     @relation("CustomerCreator", fields: [created_by], references: [id])
  orders                Order[]
  payments              Payment[]
  visits                Visit[]

  @@index([shop_name])
  @@index([phone])
  @@index([area])
  @@map("customers")
}

enum UnitType {
  PCS
  KG
  GRAM
  BOX
  LITER
}

enum InventoryMovementType {
  STOCK_ADDED
  ORDER_DEDUCTED
  MANUAL_ADJUSTMENT
  ORDER_CANCELLED_RESTORE
}

model Product {
  id                  Int       @id @default(autoincrement())
  name                String
  sku                 String    @unique
  description         String?
  purchase_price      Decimal   @db.Decimal(10, 2)
  selling_price       Decimal   @db.Decimal(10, 2)
  gst_percentage      Decimal   @db.Decimal(5, 2)
  stock_quantity      Decimal   @default(0) @db.Decimal(10, 3)
  unit_type           UnitType
  low_stock_threshold Decimal   @default(0) @db.Decimal(10, 3)
  image_url           String?
  thumbnail_url       String?
  is_active           Boolean   @default(true)
  created_by          Int
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  creator             User      @relation("ProductCreator", fields: [created_by], references: [id])
  inventory_logs      InventoryLog[]
  order_items         OrderItem[]

  @@index([name])
  @@index([sku])
  @@map("products")
}

model InventoryLog {
  id               Int                   @id @default(autoincrement())
  product_id       Int
  type             InventoryMovementType
  quantity_before  Decimal               @db.Decimal(10, 3)
  quantity_changed Decimal               @db.Decimal(10, 3)
  quantity_after   Decimal               @db.Decimal(10, 3)
  reference_id     String?
  notes            String?
  created_by       Int
  created_at       DateTime              @default(now())

  product          Product               @relation(fields: [product_id], references: [id])
  creator          User                  @relation("InventoryLogCreator", fields: [created_by], references: [id])

  @@index([product_id])
  @@map("inventory_logs")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model Order {
  id              Int           @id @default(autoincrement())
  order_number    String        @unique
  customer_id     Int
  status          OrderStatus   @default(PENDING)
  payment_status  PaymentStatus @default(UNPAID)
  total_amount    Decimal       @db.Decimal(12, 2)
  paid_amount     Decimal       @default(0) @db.Decimal(12, 2)
  pending_amount  Decimal       @db.Decimal(12, 2)
  notes           String?
  created_by      Int

  confirmed_at    DateTime?
  dispatched_at   DateTime?
  delivered_at    DateTime?
  cancelled_at    DateTime?

  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  customer        Customer      @relation(fields: [customer_id], references: [id])
  creator         User          @relation("OrderCreator", fields: [created_by], references: [id])
  items           OrderItem[]
  allocations     PaymentAllocation[]

  @@index([order_number])
  @@index([customer_id])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id              Int       @id @default(autoincrement())
  order_id        Int
  product_id      Int
  product_name    String
  quantity        Decimal   @db.Decimal(10, 3)
  unit_type       UnitType
  price_per_unit  Decimal   @db.Decimal(10, 2)
  gst_percentage  Decimal   @db.Decimal(5, 2)
  gst_amount      Decimal   @db.Decimal(10, 2)
  subtotal        Decimal   @db.Decimal(10, 2)
  total           Decimal   @db.Decimal(10, 2)

  order           Order     @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [product_id], references: [id])

  @@index([order_id])
  @@index([product_id])
  @@map("order_items")
}

enum PaymentMode {
  CASH
  BANK_TRANSFER
  UPI
  CHEQUE
  CARD
}

model Payment {
  id               Int                 @id @default(autoincrement())
  payment_number   String              @unique
  customer_id      Int
  amount           Decimal             @db.Decimal(12, 2)
  payment_mode     PaymentMode
  payment_date     DateTime
  reference_number String?
  notes            String?
  is_voided        Boolean             @default(false)
  created_by       Int
  
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt

  customer         Customer            @relation(fields: [customer_id], references: [id])
  creator          User                @relation("PaymentCreator", fields: [created_by], references: [id])
  allocations      PaymentAllocation[]

  @@index([payment_number])
  @@index([customer_id])
  @@map("payments")
}

model PaymentAllocation {
  id               Int      @id @default(autoincrement())
  payment_id       Int
  order_id         Int
  allocated_amount Decimal  @db.Decimal(12, 2)
  created_at       DateTime @default(now())

  payment          Payment  @relation(fields: [payment_id], references: [id], onDelete: Cascade)
  order            Order    @relation(fields: [order_id], references: [id])

  @@index([payment_id])
  @@index([order_id])
  @@map("payment_allocations")
}

enum VisitStatus {
  ACTIVE
  COMPLETED
  AUTO_CLOSED
}

model Visit {
  id                 Int         @id @default(autoincrement())
  salesman_id        Int
  customer_id        Int
  status             VisitStatus @default(ACTIVE)
  checkin_latitude   Decimal?    @db.Decimal(10, 6)
  checkin_longitude  Decimal?    @db.Decimal(10, 6)
  checkout_latitude  Decimal?    @db.Decimal(10, 6)
  checkout_longitude Decimal?    @db.Decimal(10, 6)
  checkin_time       DateTime    @default(now())
  checkout_time      DateTime?
  visit_duration     Int?        // Stored in seconds
  order_created      Boolean     @default(false)
  notes              String?
  
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt

  salesman           User        @relation("SalesmanVisits", fields: [salesman_id], references: [id])
  customer           Customer    @relation(fields: [customer_id], references: [id])

  @@index([salesman_id])
  @@index([customer_id])
  @@index([status])
  @@map("visits")
}
